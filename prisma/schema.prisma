generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                                   String                                @id @default(cuid())
  projectNumber                        String?
  projectName                          String
  customer                             String?
  status                               String?
  sales                                Float?
  cost                                 Float?
  hours                                Float?
  laborSales                           Float?
  laborCost                            Float?
  dateUpdated                          DateTime?
  dateCreated                          DateTime?
  projectArchived                      Boolean?                              @default(false)
  estimator                            String?
  projectManager                       String?
  customFields                         Json?
  createdAt                            DateTime                              @default(now())
  updatedAt                            DateTime                              @updatedAt
  procoreId                            String?
  bidBoardId                           String?
  customerSource                       String?
  statusSource                         String?
  activeSchedules                      ActiveSchedule[]
  commitmentContracts                  CommitmentContract[]
  productivityLogs                     ProductivityLog[]
  scopes                               ProjectScope[]
  purchaseOrderContracts               PurchaseOrderContract[]
  purchaseOrderLineItemContractDetails PurchaseOrderLineItemContractDetail[]
  schedules                            Schedule[]
  scopeTrackings                       ScopeTracking[]
  timecardEntries                      TimecardEntry[]
  timecardTimeTypes                    TimecardTimeType[]

  @@index([projectNumber])
  @@index([projectName])
  @@index([customer])
  @@index([status])
  @@index([procoreId])
  @@index([bidBoardId])
  @@index([projectArchived])
  @@index([projectArchived, status])
}

model ProjectScope {
  id             String   @id @default(cuid())
  jobKey         String
  projectId      String?
  startDate      String?
  endDate        String?
  hours          Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  description    String?
  manpower       Float?
  tasks          Json?
  title          String
  schedulingMode String   @default("contiguous")
  selectedDays   Json?
  color          String?  @db.VarChar(7)
  taskColors     Json?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([jobKey])
  @@index([projectId])
}

model Schedule {
  id              String               @id @default(cuid())
  jobKey          String               @unique
  projectId       String?
  customer        String?
  projectNumber   String?
  projectName     String?
  status          String?
  totalHours      Float?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  scheduleData    Json?
  project         Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allocationsList ScheduleAllocation[]

  @@index([jobKey])
  @@index([projectId])
  @@index([customer])
  @@index([projectNumber])
  @@index([status])
}

model ScheduleAllocation {
  id         String   @id @default(cuid())
  scheduleId String
  period     String   @db.VarChar(10)
  periodType String   @default("month")
  hours      Float
  percent    Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, period])
  @@index([scheduleId])
  @@index([period])
  @@index([periodType])
}

model ActiveSchedule {
  id           String   @id @default(cuid())
  jobKey       String
  projectId    String?
  scopeOfWork  String
  date         String   @db.VarChar(10)
  hours        Float
  foreman      String?
  manpower     Int?
  source       String
  lastModified DateTime @default(now()) @updatedAt
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([jobKey, scopeOfWork, date])
  @@index([jobKey])
  @@index([projectId])
  @@index([date])
}

model ScopeTracking {
  id               String   @id @default(cuid())
  jobKey           String
  projectId        String?
  scopeOfWork      String
  totalHours       Float
  scheduledHours   Float
  unscheduledHours Float
  lastUpdated      DateTime @default(now()) @updatedAt
  project          Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([jobKey, scopeOfWork])
  @@index([jobKey])
  @@index([projectId])
}

model ProductivityLog {
  id                               String                             @id @default(cuid())
  jobKey                           String?
  projectId                        String?
  date                             DateTime
  foreman                          String?
  crew                             String?
  hours                            Float?
  scopeOfWork                      String?
  notes                            String?
  customFields                     Json?
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  procoreId                        String?
  procoreCompanyId                 String?
  procoreProjectId                 String?
  status                           String?
  company                          String?
  contract                         String?
  lineItemId                       String?
  lineItemDescription              String?
  lineItemHolderId                 String?
  lineItemHolderType               String?
  lineItemHolderTitle              String?
  lineItemHolderNumber             String?
  quantityUsed                     Float?
  quantityDelivered                Float?
  previouslyUsed                   Float?
  previouslyDelivered              Float?
  position                         Int?
  createdById                      String?
  createdByName                    String?
  createdByLogin                   String?
  createdByCollaborator            Boolean?
  procoreCreatedAt                 DateTime?                          @db.Timestamptz(6)
  procoreUpdatedAt                 DateTime?                          @db.Timestamptz(6)
  procoreDeletedAt                 DateTime?                          @db.Timestamptz(6)
  project                          Project?                           @relation(fields: [projectId], references: [id])
  productivity_log_unpacked_fields productivity_log_unpacked_fields[]

  @@index([jobKey])
  @@index([projectId])
  @@index([date])
  @@index([procoreId])
  @@index([company])
  @@index([status])
  @@index([contract])
}

model TimecardEntry {
  id                   String                       @id @default(cuid())
  jobKey               String?
  projectId            String?
  date                 DateTime                     @db.Timestamptz(6)
  hours                Float?
  party                String?
  procoreId            String?
  procoreCompanyId     String?
  procoreProjectId     String?
  status               String?
  description          String?
  billable             Boolean?
  costCodeId           String?
  costCodeName         String?
  costCodeFullCode     String?
  subJobId             String?
  subJobName           String?
  timecardTimeTypeId   String?
  timecardTimeTypeName String?
  partyId              String?
  partyName            String?
  partyLogin           String?
  createdById          String?
  createdByName        String?
  createdByLogin       String?
  timeIn               String?
  timeOut              String?
  lunchTime            Float?
  totalHoursWorked     Float?
  procoreCreatedAt     DateTime?                    @db.Timestamptz(6)
  procoreUpdatedAt     DateTime?                    @db.Timestamptz(6)
  procoreDeletedAt     DateTime?                    @db.Timestamptz(6)
  customFields         Json?
  createdAt            DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                     @default(now()) @updatedAt @db.Timestamptz(6)
  project              Project?                     @relation(fields: [projectId], references: [id], onUpdate: NoAction, map: "fk_timecard_entry_project")
  unpackedFields       TimecardEntryUnpackedField[]

  @@index([costCodeId], map: "idx_timecard_entry_cost_code_id")
  @@index([date], map: "idx_timecard_entry_date")
  @@index([jobKey], map: "idx_timecard_entry_job_key")
  @@index([party], map: "idx_timecard_entry_party")
  @@index([procoreId], map: "idx_timecard_entry_procore_id")
  @@index([projectId], map: "idx_timecard_entry_project_id")
  @@index([status], map: "idx_timecard_entry_status")
}

model TimecardTimeType {
  id                                 String                               @id @default(dbgenerated("(gen_random_uuid())::text"))
  jobKey                             String?
  projectId                          String?
  procoreId                          String?
  procoreCompanyId                   String?
  procoreProjectId                   String?
  name                               String?
  active                             Boolean?
  global                             Boolean?
  procoreCreatedAt                   DateTime?                            @db.Timestamptz(6)
  procoreUpdatedAt                   DateTime?                            @db.Timestamptz(6)
  procoreDeletedAt                   DateTime?                            @db.Timestamptz(6)
  customFields                       Json?
  createdAt                          DateTime                             @default(now()) @db.Timestamptz(6)
  updatedAt                          DateTime                             @default(now()) @updatedAt @db.Timestamptz(6)
  project                            Project?                             @relation(fields: [projectId], references: [id], onUpdate: NoAction)
  timecard_time_type_unpacked_fields timecard_time_type_unpacked_fields[]

  @@index([jobKey])
  @@index([projectId])
  @@index([procoreId])
  @@index([name])
}

model CommitmentContract {
  id                                  String                                @id @default(dbgenerated("(gen_random_uuid())::text"))
  jobKey                              String?
  projectId                           String?
  procoreId                           String?
  procoreCompanyId                    String?
  procoreProjectId                    String?
  title                               String?
  number                              String?
  status                              String?
  vendorId                            String?
  vendorName                          String?
  value                               Float?
  originalValue                       Float?
  startDate                           DateTime?                             @db.Timestamptz(6)
  completionDate                      DateTime?                             @db.Timestamptz(6)
  approvalLetterDate                  DateTime?                             @db.Timestamptz(6)
  signedContractDate                  DateTime?                             @db.Timestamptz(6)
  notes                               String?
  procoreCreatedAt                    DateTime?                             @db.Timestamptz(6)
  procoreUpdatedAt                    DateTime?                             @db.Timestamptz(6)
  procoreDeletedAt                    DateTime?                             @db.Timestamptz(6)
  customFields                        Json?
  createdAt                           DateTime                              @default(now()) @db.Timestamptz(6)
  updatedAt                           DateTime                              @default(now()) @updatedAt @db.Timestamptz(6)
  project                             Project?                              @relation(fields: [projectId], references: [id], onUpdate: NoAction)
  commitment_contract_unpacked_fields commitment_contract_unpacked_fields[]

  @@index([jobKey])
  @@index([projectId])
  @@index([procoreId])
  @@index([number])
  @@index([status])
  @@index([vendorId])
}

model CommitmentChangeOrder {
  id                String    @id @default(cuid())
  jobKey            String?
  projectId         String?
  procoreId         String?
  procoreCompanyId  String?
  procoreProjectId  String?
  procoreContractId String?
  title             String?
  number            String?
  status            String?
  dueDate           DateTime? @db.Timestamptz(6)
  invoicedDate      DateTime? @db.Timestamptz(6)
  approvedDate      DateTime? @db.Timestamptz(6)
  value             Float?
  customFields      Json?
  procoreCreatedAt  DateTime? @db.Timestamptz(6)
  procoreUpdatedAt  DateTime? @db.Timestamptz(6)
  procoreDeletedAt  DateTime? @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([procoreContractId], map: "idx_cco_contract_id")
  @@index([jobKey], map: "idx_cco_job_key")
  @@index([number], map: "idx_cco_number")
  @@index([procoreId], map: "idx_cco_procore_id")
  @@index([projectId], map: "idx_cco_project_id")
  @@index([status], map: "idx_cco_status")
}

model CommitmentChangeOrderLineItem {
  id                                                String                                              @id @default(cuid())
  jobKey                                            String?
  projectId                                         String?
  changeOrderId                                     String?
  procoreId                                         String?
  procoreCompanyId                                  String?
  procoreProjectId                                  String?
  procoreChangeOrderId                              String?
  description                                       String?
  quantity                                          Float?
  unitCost                                          Float?
  totalAmount                                       Float?
  uom                                               String?
  position                                          Int?
  wbsCode                                           String?
  costCode                                          String?
  costType                                          String?
  customFields                                      Json?
  procoreCreatedAt                                  DateTime?                                           @db.Timestamptz(6)
  procoreUpdatedAt                                  DateTime?                                           @db.Timestamptz(6)
  createdAt                                         DateTime                                            @default(now()) @db.Timestamptz(6)
  updatedAt                                         DateTime                                            @default(now()) @updatedAt @db.Timestamptz(6)
  commitment_change_order_line_item_unpacked_fields commitment_change_order_line_item_unpacked_fields[]

  @@index([changeOrderId], map: "idx_ccoli_change_order_id")
  @@index([costCode], map: "idx_ccoli_cost_code")
  @@index([jobKey], map: "idx_ccoli_job_key")
  @@index([procoreChangeOrderId], map: "idx_ccoli_procore_co_id")
  @@index([procoreId], map: "idx_ccoli_procore_id")
  @@index([projectId], map: "idx_ccoli_project_id")
}

model PurchaseOrderContract {
  id                      String                                @id @default(cuid())
  jobKey                  String?
  projectId               String?
  procoreId               String?
  procoreCompanyId        String?
  procoreProjectId        String?
  title                   String?
  number                  String?
  status                  String?
  vendorId                String?
  vendorName              String?
  value                   Float?
  originalValue           Float?
  startDate               DateTime?                             @db.Timestamptz(6)
  completionDate          DateTime?                             @db.Timestamptz(6)
  customFields            Json?
  procoreCreatedAt        DateTime?                             @db.Timestamptz(6)
  procoreUpdatedAt        DateTime?                             @db.Timestamptz(6)
  procoreDeletedAt        DateTime?                             @db.Timestamptz(6)
  createdAt               DateTime                              @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime                              @default(now()) @updatedAt @db.Timestamptz(6)
  project                 Project?                              @relation(fields: [projectId], references: [id], onUpdate: NoAction, map: "fk_poc_project")
  lineItemContractDetails PurchaseOrderLineItemContractDetail[]

  @@index([jobKey], map: "idx_poc_job_key")
  @@index([number], map: "idx_poc_number")
  @@index([procoreId], map: "idx_poc_procore_id")
  @@index([projectId], map: "idx_poc_project_id")
  @@index([status], map: "idx_poc_status")
  @@index([vendorId], map: "idx_poc_vendor_id")
}

model PurchaseOrderLineItemContractDetail {
  id                                                       String                                                     @id @default(cuid())
  jobKey                                                   String?
  projectId                                                String?
  purchaseOrderContractId                                  String?
  procoreId                                                String?
  procoreCompanyId                                         String?
  procoreProjectId                                         String?
  procorePurchaseOrderContractId                           String?
  description                                              String?
  quantity                                                 Float?
  unitCost                                                 Float?
  totalAmount                                              Float?
  uom                                                      String?
  position                                                 Int?
  wbsCode                                                  String?
  costCode                                                 String?
  costType                                                 String?
  customFields                                             Json?
  procoreCreatedAt                                         DateTime?                                                  @db.Timestamptz(6)
  procoreUpdatedAt                                         DateTime?                                                  @db.Timestamptz(6)
  createdAt                                                DateTime                                                   @default(now()) @db.Timestamptz(6)
  updatedAt                                                DateTime                                                   @default(now()) @updatedAt @db.Timestamptz(6)
  purchaseOrderContract                                    PurchaseOrderContract?                                     @relation(fields: [purchaseOrderContractId], references: [id], onUpdate: NoAction, map: "fk_pold_contract")
  project                                                  Project?                                                   @relation(fields: [projectId], references: [id], onUpdate: NoAction, map: "fk_pold_project")
  purchase_order_line_item_contract_detail_unpacked_fields purchase_order_line_item_contract_detail_unpacked_fields[]

  @@index([purchaseOrderContractId], map: "idx_pold_contract_id")
  @@index([procorePurchaseOrderContractId], map: "idx_pold_contract_procore_id")
  @@index([costCode], map: "idx_pold_cost_code")
  @@index([jobKey], map: "idx_pold_job_key")
  @@index([procoreId], map: "idx_pold_procore_id")
  @@index([projectId], map: "idx_pold_project_id")
}

model commitment_change_order_line_item_unpacked_fields {
  id                            BigInt                        @id @default(autoincrement())
  line_item_id                  String
  field_path                    String
  value_type                    String
  value_text                    String?
  value_number                  Float?
  value_boolean                 Boolean?
  value_json                    Json
  created_at                    DateTime                      @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime                      @default(now()) @updatedAt @db.Timestamptz(6)
  CommitmentChangeOrderLineItem CommitmentChangeOrderLineItem @relation(fields: [line_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ccoli_unpacked_line_item")

  @@unique([line_item_id, field_path], map: "commitment_change_order_line_item_u_line_item_id_field_path_key")
  @@index([field_path], map: "idx_ccoli_uf_field_path")
  @@index([value_text], map: "idx_ccoli_uf_value_text")
  @@index([value_number], map: "idx_ccoli_uf_value_number")
  @@index([value_boolean], map: "idx_ccoli_uf_value_boolean")
  @@index([field_path, value_text], map: "idx_ccoli_uf_path_text")
  @@index([field_path], map: "idx_ccoli_unpacked_field_path")
  @@index([field_path, value_text], map: "idx_ccoli_unpacked_path_text")
  @@index([value_boolean], map: "idx_ccoli_unpacked_value_boolean")
  @@index([value_number], map: "idx_ccoli_unpacked_value_number")
  @@index([value_text], map: "idx_ccoli_unpacked_value_text")
}

model commitment_contract_unpacked_fields {
  id                 BigInt             @id @default(autoincrement())
  contract_id        String
  field_path         String
  value_type         String
  value_text         String?
  value_number       Float?
  value_boolean      Boolean?
  value_json         Json
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  CommitmentContract CommitmentContract @relation(fields: [contract_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_commitment_unpacked_contract")

  @@unique([contract_id, field_path])
  @@index([field_path], map: "idx_cc_unpacked_field_path")
  @@index([field_path, value_text], map: "idx_cc_unpacked_path_text")
  @@index([value_boolean], map: "idx_cc_unpacked_value_boolean")
  @@index([value_number], map: "idx_cc_unpacked_value_number")
  @@index([value_text], map: "idx_cc_unpacked_value_text")
}

model purchase_order_line_item_contract_detail_unpacked_fields {
  id                                  BigInt                              @id @default(autoincrement())
  detail_id                           String
  field_path                          String
  value_type                          String
  value_text                          String?
  value_number                        Float?
  value_boolean                       Boolean?
  value_json                          Json
  created_at                          DateTime                            @default(now()) @db.Timestamptz(6)
  updated_at                          DateTime                            @default(now()) @updatedAt @db.Timestamptz(6)
  PurchaseOrderLineItemContractDetail PurchaseOrderLineItemContractDetail @relation(fields: [detail_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pold_unpacked_detail")

  @@unique([detail_id, field_path], map: "purchase_order_line_item_contract_deta_detail_id_field_path_key")
  @@index([field_path], map: "idx_pold_uf_field_path")
  @@index([value_text], map: "idx_pold_uf_value_text")
  @@index([value_number], map: "idx_pold_uf_value_number")
  @@index([value_boolean], map: "idx_pold_uf_value_boolean")
  @@index([field_path, value_text], map: "idx_pold_uf_path_text")
}

model PmcGroupMapping {
  id           String   @id @default(cuid())
  costItem     String
  costType     String?
  pmcGroup     String
  costItemNorm String
  costTypeNorm String
  source       String?  @default("manual")
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([costItem, costTypeNorm, pmcGroup])
  @@index([costItemNorm], map: "PmcGroupMapping_costitem_idx")
  @@index([costTypeNorm], map: "PmcGroupMapping_costtype_idx")
  @@index([pmcGroup], map: "PmcGroupMapping_group_idx")
}

model DashboardSummary {
  id             String   @id @default("summary")
  totalSales     Float
  totalCost      Float
  totalHours     Float
  statusGroups   Json
  contractors    Json
  pmcGroupHours  Json
  laborBreakdown Json?
  lastUpdated    DateTime @updatedAt

  @@index([id])
}

model KPIEntry {
  id                   String   @id @default(cuid())
  entryKey             String   @unique
  year                 String
  month                Int
  monthName            String
  bidSubmittedSales    Float?
  scheduledSales       Float?
  subs                 Float?
  estimates            Float?
  grossProfit          Float?
  cost                 Float?
  bidSubmittedHours    Float?
  scheduledHours       Float?
  leadtimes            Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  createdByEmail       String?
  updatedByEmail       String?
  estimatesActualHours Float?
  gpActualPercent      Float?
  profitActualPercent  Float?
  revenueActual        Float?
  revenueActualHours   Float?
  salesActualHours     Float?
  subActualHours       Float?
  subsAllowance        Float?

  @@index([year, month])
  @@index([entryKey])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  userEmail String
  changes   Json?
  createdAt DateTime @default(now())

  @@index([entityId])
  @@index([userEmail])
  @@index([createdAt])
}

model Employee {
  id             String          @id @default(cuid())
  firstName      String
  lastName       String
  jobTitle       String?
  email          String?         @unique
  phone          String?
  isActive       Boolean         @default(true)
  customFields   Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  certifications Certification[]

  @@index([jobTitle])
  @@index([isActive])
  @@index([firstName, lastName])
  @@index([isActive, firstName, lastName])
}

model JobTitle {
  id        String   @id @default(cuid())
  title     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}

model Holiday {
  id          String   @id @default(cuid())
  date        String   @db.VarChar(10)
  name        String
  description String?
  isPaid      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model TimeOffRequest {
  id           String   @id @default(cuid())
  employeeId   String
  employeeName String?
  dates        Json
  reason       String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}

model CrewTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  members     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model HandbookSignoff {
  id          String   @id @default(cuid())
  email       String   @unique @db.VarChar(255)
  displayName String?
  userAgent   String?
  signedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

model EstimatingConstant {
  id        String   @id @default(cuid())
  name      String   @unique
  value     String
  category  String   @default("General")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model RebarConstant {
  id        String   @id @default(cuid())
  size      String
  weight    Float
  spacing   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([size])
}

model Certification {
  id             String   @id @default(cuid())
  employeeId     String
  type           String
  issueDate      String
  expirationDate String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([expirationDate])
  @@index([employeeId, expirationDate])
}

model Equipment {
  id           String   @id @default(cuid())
  name         String
  type         String
  make         String?
  model        String?
  serialNumber String?  @unique
  status       String   @default("Available")
  hourlyRate   Float?
  dailyRate    Float?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([name])
  @@index([type, name])
}

model EquipmentAssignment {
  id          String   @id @default(cuid())
  equipmentId String
  projectId   String?
  scopeId     String?
  startDate   String
