// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== PROJECTS ====================
model Project {
  id              String    @id @default(cuid())
  procoreId       String?
  bidBoardId      String?
  projectNumber   String?
  projectName     String
  customer        String?
  customerSource  String?
  status          String? // "Bid Submitted", "Estimating", "In Progress", etc.
  statusSource    String?
  sales           Float?
  cost            Float?
  hours           Float?
  laborSales      Float?
  laborCost       Float?
  dateUpdated     DateTime?
  dateCreated     DateTime?
  projectArchived Boolean?  @default(false)
  estimator       String?
  projectManager  String?

  // Flexible data (store as JSON for fields not explicitly modeled)
  customFields Json?

  // Relationships
  scopes                ProjectScope[]
  schedules             Schedule[]
  activeSchedules       ActiveSchedule[]
  scopeTrackings        ScopeTracking[]
  productivityLogs      ProductivityLog[]
  timecardEntries       TimecardEntry[]
  timecardTimeTypes     TimecardTimeType[]
  commitmentContracts   CommitmentContract[]
  commitmentChangeOrders CommitmentChangeOrder[]
  commitmentChangeOrderLineItems CommitmentChangeOrderLineItem[]
  purchaseOrderContracts PurchaseOrderContract[]
  purchaseOrderLineItemContractDetails PurchaseOrderLineItemContractDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectNumber])
  @@index([projectName])
  @@index([customer])
  @@index([status])
  @@index([procoreId])
  @@index([bidBoardId])
  @@index([projectArchived])
  @@index([projectArchived, status])
}

// ==================== PROJECT SCOPES (Gantt Chart) ====================
model ProjectScope {
  id        String   @id @default(cuid())
  jobKey    String // Format: "customer~projectNumber~projectName"
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String // Scope title/name
  startDate   String? // YYYY-MM-DD format
  endDate     String? // YYYY-MM-DD format
  manpower    Float? // Daily manpower
  hours       Float? // Total hours
  description String? @db.Text
  tasks       Json? // Array of task strings
  color       String? // Hex color code for scope (e.g., "#3B82F6")
  taskColors  Json? // Map of task names to color codes for individual task colors
  schedulingMode String @default("contiguous") // contiguous | specific-days
  selectedDays Json? // Array<{ date: string, hours: number, foreman?: string | null }>

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
}

// ==================== SCHEDULES (WIP - Work In Progress) ====================
model Schedule {
  id        String   @id @default(cuid())
  jobKey    String   @unique
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  customer      String?
  projectNumber String?
  projectName   String?
  status        String?
  totalHours    Float?

  // Normalized allocations table (single source of truth)
  allocationsList ScheduleAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
  @@index([customer])
  @@index([projectNumber])
  @@index([status])
}

// ==================== SCHEDULE ALLOCATIONS (Monthly/Weekly breakdown) ====================
model ScheduleAllocation {
  id         String   @id @default(cuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  period     String @db.VarChar(10) // "2026-03" for month, "2026-W10" for week
  periodType String @default("month") // "month" or "week"
  hours      Float
  percent    Float? // Percentage of total hours

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scheduleId, period])
  @@index([scheduleId])
  @@index([period])
  @@index([periodType])
}

// ==================== ACTIVE SCHEDULE ====================
model ActiveSchedule {
  id        String   @id @default(cuid())
  jobKey    String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scopeOfWork String
  date        String  @db.VarChar(10) // YYYY-MM-DD format
  hours       Float
  foreman     String?
  manpower    Int?
  source      String // 'gantt' | 'short-term' | 'long-term' | 'schedules'

  lastModified DateTime @default(now()) @updatedAt

  @@unique([jobKey, scopeOfWork, date]) // Composite unique constraint
  @@index([jobKey])
  @@index([projectId])
  @@index([date])
}

// ==================== SCOPE TRACKING ====================
model ScopeTracking {
  id        String   @id @default(cuid())
  jobKey    String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scopeOfWork      String
  totalHours       Float
  scheduledHours   Float
  unscheduledHours Float

  lastUpdated DateTime @default(now()) @updatedAt

  @@unique([jobKey, scopeOfWork])
  @@index([jobKey])
  @@index([projectId])
}

// ==================== PRODUCTIVITY ====================
model ProductivityLog {
  id        String   @id @default(cuid())
  jobKey    String?
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  date        DateTime
  foreman     String?
  crew        String?
  hours       Float?
  scopeOfWork String?
  notes       String?

  // Procore payload columns – promoted from customFields for direct queryability
  procoreId             String?
  procoreCompanyId      String?
  procoreProjectId      String?
  status                String?
  company               String?
  contract              String?
  lineItemId            String?
  lineItemDescription   String?
  lineItemHolderId      String?
  lineItemHolderType    String?
  lineItemHolderTitle   String?
  lineItemHolderNumber  String?
  quantityUsed          Float?
  quantityDelivered     Float?
  previouslyUsed        Float?
  previouslyDelivered   Float?
  position              Int?
  createdById           String?
  createdByName         String?
  createdByLogin        String?
  createdByCollaborator Boolean?
  procoreCreatedAt      DateTime?
  procoreUpdatedAt      DateTime?
  procoreDeletedAt      DateTime?

  // Flexible data
  customFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
  @@index([date])
  @@index([procoreId])
  @@index([company])
  @@index([status])
  @@index([contract])
}

// ==================== TIMECARD ENTRIES ====================
model TimecardEntry {
  id        String   @id @default(cuid())
  jobKey    String?
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  date  DateTime
  hours Float?
  party String? // party.name (who worked)

  // Procore payload columns – promoted from customFields for direct queryability
  procoreId            String?
  procoreCompanyId     String?
  procoreProjectId     String?
  status               String?
  description          String?
  billable             Boolean?
  costCodeId           String?
  costCodeName         String?
  costCodeFullCode     String?
  subJobId             String?
  subJobName           String?
  timecardTimeTypeId   String?
  timecardTimeTypeName String?
  partyId              String?
  partyName            String?
  partyLogin           String?
  createdById          String?
  createdByName        String?
  createdByLogin       String?
  timeIn               String?
  timeOut              String?
  lunchTime            Float?
  totalHoursWorked     Float?
  procoreCreatedAt     DateTime?
  procoreUpdatedAt     DateTime?
  procoreDeletedAt     DateTime?

  // Flexible data
  customFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unpackedFields    TimecardEntryUnpackedField[]

  @@index([jobKey])
  @@index([projectId])
  @@index([date])
  @@index([procoreId])
  @@index([party])
  @@index([status])
  @@index([costCodeId])
}

model TimecardTimeType {
  id               String   @id @default(cuid())
  jobKey           String?
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  procoreId        String?
  procoreCompanyId String?
  procoreProjectId String?
  name             String?
  active           Boolean?
  global           Boolean?

  procoreCreatedAt DateTime?
  procoreUpdatedAt DateTime?
  procoreDeletedAt DateTime?

  customFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
  @@index([procoreId])
  @@index([name])
}

model CommitmentContract {
  id               String   @id @default(cuid())
  jobKey           String?
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  procoreId           String?
  procoreCompanyId    String?
  procoreProjectId    String?
  title               String?
  number              String?
  status              String?
  vendorId            String?
  vendorName          String?
  value               Float?
  originalValue       Float?
  startDate           DateTime?
  completionDate      DateTime?
  approvalLetterDate  DateTime?
  signedContractDate  DateTime?
  notes               String?

  procoreCreatedAt DateTime?
  procoreUpdatedAt DateTime?
  procoreDeletedAt DateTime?

  customFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
  @@index([procoreId])
  @@index([number])
  @@index([status])
  @@index([vendorId])
}

model CommitmentChangeOrder {
  id               String   @id @default(cuid())
  jobKey           String?
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  procoreId            String?
  procoreCompanyId     String?
  procoreProjectId     String?
  procoreContractId    String?

  title            String?
  number           String?
  status           String?
  dueDate          DateTime?
  invoicedDate     DateTime?
  approvedDate     DateTime?
  value            Float?

  customFields     Json?

  procoreCreatedAt DateTime?
  procoreUpdatedAt DateTime?
  procoreDeletedAt DateTime?

  lineItems        CommitmentChangeOrderLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
  @@index([procoreId])
  @@index([procoreContractId])
  @@index([number])
  @@index([status])
}

model CommitmentChangeOrderLineItem {
  id               String   @id @default(cuid())
  jobKey           String?
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  changeOrderId    String?
  changeOrder      CommitmentChangeOrder? @relation(fields: [changeOrderId], references: [id], onDelete: SetNull)

  procoreId            String?
  procoreCompanyId     String?
  procoreProjectId     String?
  procoreChangeOrderId String?

  description      String?
  quantity         Float?
  unitCost         Float?
  totalAmount      Float?
  uom              String?
  position         Int?
  wbsCode          String?
  costCode         String?
  costType         String?

  customFields     Json?

  procoreCreatedAt DateTime?
  procoreUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
  @@index([changeOrderId])
  @@index([procoreId])
  @@index([procoreChangeOrderId])
  @@index([costCode])
}

model PurchaseOrderContract {
  id               String   @id @default(cuid())
  jobKey           String?
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  procoreId            String?
  procoreCompanyId     String?
  procoreProjectId     String?

  title            String?
  number           String?
  status           String?
  vendorId         String?
  vendorName       String?
  value            Float?
  originalValue    Float?
  startDate        DateTime?
  completionDate   DateTime?

  customFields     Json?

  procoreCreatedAt DateTime?
  procoreUpdatedAt DateTime?
  procoreDeletedAt DateTime?

  lineItemContractDetails PurchaseOrderLineItemContractDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
  @@index([procoreId])
  @@index([number])
  @@index([status])
  @@index([vendorId])
}

model PurchaseOrderLineItemContractDetail {
  id               String   @id @default(cuid())
  jobKey           String?
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  purchaseOrderContractId String?
  purchaseOrderContract   PurchaseOrderContract? @relation(fields: [purchaseOrderContractId], references: [id], onDelete: SetNull)

  procoreId               String?
  procoreCompanyId        String?
  procoreProjectId        String?
  procorePurchaseOrderContractId String?

  description      String?
  quantity         Float?
  unitCost         Float?
  totalAmount      Float?
  uom              String?
  position         Int?
  wbsCode          String?
  costCode         String?
  costType         String?

  customFields     Json?

  procoreCreatedAt DateTime?
  procoreUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobKey])
  @@index([projectId])
  @@index([purchaseOrderContractId])
  @@index([procoreId])
  @@index([procorePurchaseOrderContractId])
  @@index([costCode])
}

model commitment_change_order_line_item_unpacked_fields {
  id              BigInt   @id @default(autoincrement())
  line_item_id    String
  field_path      String
  value_type      String
  value_text      String?
  value_number    Float?
  value_boolean   Boolean?
  value_json      Json
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  @@unique([line_item_id, field_path])
  @@index([field_path], map: "idx_ccoli_uf_field_path")
  @@index([value_text], map: "idx_ccoli_uf_value_text")
  @@index([value_number], map: "idx_ccoli_uf_value_number")
  @@index([value_boolean], map: "idx_ccoli_uf_value_boolean")
  @@index([field_path, value_text], map: "idx_ccoli_uf_path_text")
}

model commitment_contract_unpacked_fields {
  id           BigInt    @id @default(autoincrement())
  contract_id  String
  field_path   String
  value_type   String
  value_text   String?
  value_number Float?
  value_boolean Boolean?
  value_json   Json
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz

  @@unique([contract_id, field_path])
  @@index([field_path])
  @@index([value_text])
  @@index([value_number])
  @@index([value_boolean])
  @@index([field_path, value_text])
}

model purchase_order_line_item_contract_detail_unpacked_fields {
  id              BigInt   @id @default(autoincrement())
  detail_id       String
  field_path      String
  value_type      String
  value_text      String?
  value_number    Float?
  value_boolean   Boolean?
  value_json      Json
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  @@unique([detail_id, field_path])
  @@index([field_path], map: "idx_pold_uf_field_path")
  @@index([value_text], map: "idx_pold_uf_value_text")
  @@index([value_number], map: "idx_pold_uf_value_number")
  @@index([value_boolean], map: "idx_pold_uf_value_boolean")
  @@index([field_path, value_text], map: "idx_pold_uf_path_text")
}

model PmcGroupMapping {
  id           String   @id @default(cuid())
  costItem     String
  costType     String?
  pmcGroup     String
  costItemNorm String
  costTypeNorm String
  source       String?  @default("manual")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([costItem, costTypeNorm, pmcGroup])
  @@index([costItemNorm])
  @@index([costTypeNorm])
  @@index([pmcGroup])
}

// ==================== DASHBOARD SUMMARY ====================
model DashboardSummary {
  id String @id @default("summary")

  totalSales Float
  totalCost  Float
  totalHours Float

  statusGroups   Json // Record<string, { sales, cost, hours, count, laborByGroup }>
  contractors    Json // Record<string, { sales, cost, hours, count, byStatus }>
  pmcGroupHours  Json // Record<string, number>
  laborBreakdown Json? // Record<string, number>

  lastUpdated DateTime @updatedAt

  @@index([id])
}

// ==================== KPI DATA ====================
model KPIEntry {
  id        String @id @default(cuid())
  entryKey  String @unique // Format: "2026-01" (year-month)
  year      String
  month     Int
  monthName String

  // Financial Metrics - Database Fed
  bidSubmittedSales Float?
  scheduledSales    Float?
  bidSubmittedHours Float?
  scheduledHours    Float?
  leadtimes         Float?

  // Financial Metrics - Manual Entry
  revenueActual        Float? // Revenue by Month - manual
  estimates            Float? // Estimates by Month - Goal (manual)
  estimatesActualHours Float? // Estimates by Month - Actual Hours (manual)
  salesActualHours     Float? // Sales by Month - Actual Hours (manual)
  revenueActualHours   Float? // Revenue Hours by Month - Actual Hours (manual)
  subsAllowance        Float? // Subs by Month - Subcontractor Allowance (manual)
  subActualHours       Float? // Subs by Month - Sub Actual Hours (manual)
  gpActualPercent      Float? // Gross Profit by Month - GP Actual % (manual)
  profitActualPercent  Float? // Profit by Month - Profit Actual % (manual)

  // Legacy/Unused Fields
  subs        Float? // Deprecated: use subActualHours
  grossProfit Float? // Deprecated: use gpActualPercent
  cost        Float? // Deprecated: not currently used

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optional: Link to user who created/edited
  createdByEmail String?
  updatedByEmail String?

  @@index([year, month])
  @@index([entryKey])
}

// ==================== AUDIT LOG ====================
model AuditLog {
  id        String   @id @default(cuid())
  action    String // "CREATE", "UPDATE", "DELETE"
  entity    String // "Project", "KPIEntry", etc.
  entityId  String
  userEmail String
  changes   Json? // Store what changed
  createdAt DateTime @default(now())

  @@index([entityId])
  @@index([userEmail])
  @@index([createdAt])
}

// ==================== EMPLOYEES ====================
model Employee {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  jobTitle  String?
  email     String? @unique
  phone     String?
  isActive  Boolean @default(true)

  // Flexible data for additional fields
  customFields Json?

  // Relations
  certifications Certification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobTitle])
  @@index([isActive])
  @@index([firstName, lastName])
  @@index([isActive, firstName, lastName])
}

model JobTitle {
  id        String   @id @default(cuid())
  title     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}

// ==================== HOLIDAYS ====================
model Holiday {
  id          String  @id @default(cuid())
  date        String  @db.VarChar(10) // YYYY-MM-DD format
  name        String
  description String?
  isPaid      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// ==================== TIME OFF REQUESTS ====================
model TimeOffRequest {
  id           String  @id @default(cuid())
  employeeId   String
  employeeName String?
  dates        Json // Array of date strings
  reason       String?
  status       String  @default("pending") // pending, approved, denied

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}

// ==================== CREW TEMPLATES ====================
model CrewTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  members     Json // Array of employee IDs or employee data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// ==================== HANDBOOK SIGNOFFS ====================
model HandbookSignoff {
  id          String   @id @default(cuid())
  email       String   @unique @db.VarChar(255)
  displayName String?
  userAgent   String?
  signedAt    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ==================== ESTIMATING CONSTANTS ====================
model EstimatingConstant {
  id       String @id @default(cuid())
  name     String @unique
  value    String // Can be numeric string or any value
  category String @default("General")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model RebarConstant {
  id      String @id @default(cuid())
  size    String // e.g., "#1", "#2", etc.
  weight  Float // Weight per unit
  spacing Float? // Spacing information

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([size])
}

// ==================== CERTIFICATIONS ====================
model Certification {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type           String
  issueDate      String // YYYY-MM-DD
  expirationDate String // YYYY-MM-DD
  notes          String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([expirationDate])
  @@index([employeeId, expirationDate])
}

// ==================== EQUIPMENT ====================
model Equipment {
  id           String  @id @default(cuid())
  name         String
  type         String // e.g., "Truck", "Excavator", etc.
  make         String?
  model        String?
  serialNumber String? @unique

  status     String  @default("Available") // Available, In Use, Maintenance
  hourlyRate Float?
  dailyRate  Float?
  notes      String? @db.Text
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([name])
  @@index([type, name])
}

model EquipmentAssignment {
  id          String  @id @default(cuid())
  equipmentId String
  projectId   String?
  scopeId     String?

  startDate String // YYYY-MM-DD
  endDate   String // YYYY-MM-DD
  notes     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([equipmentId])
  @@index([projectId])
  @@index([startDate])
}

// ==================== ONBOARDING ====================
model OnboardingSubmission {
  id          String  @id @default(cuid())
  email       String
  displayName String?

  submittedAt DateTime
  hasBooklet  Boolean? // Understanding of Handbook
  hasHandbook Boolean? // Employee Handbook Receipt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([submittedAt])
  @@index([email, submittedAt])
}

// ==================== STATUS CSV SNAPSHOT ====================
model Status {
  id             String   @id @default(cuid())
  customer       String?
  projectNumber  String?
  projectName    String?
  status         String?
  testProject    Boolean?
  active         Boolean?
  dateCreatedRaw String?
  estimator      String?
  projectStage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customer])
  @@index([projectNumber])
  @@index([projectName])
  @@index([status])
  @@index([active])
  @@index([testProject])
  @@index([customer, projectName])
  @@index([status, active])
  @@map("Status")
}

// ==================== ESTIMATES ====================
model Estimate {
  id        String  @id @default(cuid())
  projectId String?

  title          String
  description    String? @db.Text
  estimatedHours Float?
  estimatedCost  Float?
  status         String  @default("Draft") // Draft, Submitted, Approved, Completed

  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

// ==================== PMC GROUPS & CLASSIFICATION ====================
model PMCGroup {
  id           String  @id @default(cuid())
  code         String // e.g., "SITE", "FOUNDATION", "STRUCTURES", "INTERIOR", "SPECIAL"
  name         String // Display name: "Site Work", "Foundation", etc.
  description  String? @db.Text
  color        String? // Hex color for UI: #FF5733
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // Relationships
  costitemMappings CostitemPMCMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code])
  @@index([code])
  @@index([isActive])
}

model CostitemPMCMapping {
  id         String    @id @default(cuid())
  costitem   String    @unique // The exact Costitem string from CSV (e.g., "Slab On Grade Labor")
  pmcGroupId String?
  pmcGroup   PMCGroup? @relation(fields: [pmcGroupId], references: [id], onDelete: SetNull)

  // Fallback PMC code if relation is null (useful for imports before PMCGroup exists)
  pmcGroupCode String? // e.g., "FOUNDATION"

  // Audit trail
  mappedByEmail String?
  source        String  @default("seed") // "seed", "imported", "manual"
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([costitem])
  @@index([pmcGroupId])
  @@index([pmcGroupCode])
  @@index([source])
}

