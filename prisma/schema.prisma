// ==================== GANTT V2 SCHEMA ====================
model GanttV2Project {
  id            String                @id @db.Text
  projectName   String                @map("project_name")
  customer      String?               @db.Text
  projectNumber String?               @db.Text
  status        String?               @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  
  scopes        GanttV2Scope[]

  @@map("gantt_v2_projects")
}

model GanttV2Scope {
  id            String                    @id @db.Text
  projectId     String                    @map("project_id")
  predecessorScopeId String?              @map("predecessor_scope_id") @db.Text
  title         String                    @db.Text
  startDate     DateTime?                 @map("start_date") @db.Date
  endDate       DateTime?                 @map("end_date") @db.Date
  totalHours    Float                     @default(0) @map("total_hours")
  crewSize      Float?                    @map("crew_size")
  notes         String?                   @db.Text
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")
  
  project       GanttV2Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  predecessor   GanttV2Scope?             @relation("GanttV2ScopeDependency", fields: [predecessorScopeId], references: [id], onDelete: SetNull)
  successors    GanttV2Scope[]            @relation("GanttV2ScopeDependency")
  scheduleEntries GanttV2ScheduleEntry[]

  @@index([projectId])
  @@index([predecessorScopeId])
  @@map("gantt_v2_scopes")
}

model GanttV2ScheduleEntry {
  id              String        @id @db.Text
  scopeId         String        @map("scope_id")
  workDate        DateTime      @map("work_date") @db.Date
  scheduledHours  Float         @default(0) @map("scheduled_hours")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  
  scope           GanttV2Scope  @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([scopeId])
  @@map("gantt_v2_schedule_entries")
}

